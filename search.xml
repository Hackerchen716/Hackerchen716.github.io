        <content type="html"><![CDATA[<h1 id="PHPINFO"><a href="#PHPINFO" class="headerlink" title="PHPINFO:"></a>PHPINFO:</h1><h3 id="Way1-command-F"><a href="#Way1-command-F" class="headerlink" title="Way1: command + F"></a>Way1: command + F</h3><p><img src="/assets/1.png"></p><h3 id="Way2-curl-grep"><a href="#Way2-curl-grep" class="headerlink" title="Way2: curl &amp; grep"></a>Way2: curl &amp; grep</h3><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">curl -s http://challenge-39113f980a5fa8d4.sandbox.ctfhub.com:10800/phpinfo.php | grep -o <span class="string">&#x27;ctfhub&#123;[^&#125;]*&#125;&#x27;</span></span><br></pre></td></tr></table></figure><p><img src="/assets/2.png"></p>]]></content>
      
      
      
    </entry>
    
    
    
